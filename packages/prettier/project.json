{
  "name": "prettier",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/prettier/src",
  "projectType": "library",
  "targets": {
    "build-json": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "pnpm copyfiles packages/prettier/src/recommended.json tmp",
          "mv tmp/packages/prettier/src/recommended.json packages/prettier/src/config.json",
          "pnpm copyfiles --up=3 packages/prettier/src/{*.json,.prettierignore,.prettierignore-exclude-packagejson} packages/prettier/dist"
        ],
        "parallel": false
      }
    },
    "build-base": {
      "executor": "nx:run-commands",
      "dependsOn": ["clean", "^build"],
      "options": {
        "command": "tsdown --config=tsdown.config.ts",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["build-base", "build-json"],
      "options": {
        "commands": [
          "pnpm copyfiles LICENSE dist/packages/prettier",
          "pnpm copyfiles --up=2 ./packages/prettier/*.md ./packages/prettier/package.json dist/packages/prettier",
          "pnpm copyfiles --up=3 \"./packages/prettier/dist/**/*\" dist/packages/prettier"
        ]
      }
    },
    "nx-release-publish": {
      "executor": "@storm-software/workspace-tools:npm-publish"
    }
  }
}
