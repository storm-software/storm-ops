{
  "name": "@storm-software/prettier",
  "version": "0.59.133",
  "private": false,
  "description": "⚡ A package containing the base Prettier configuration used by Storm Software across many projects.",
  "keywords": [
    "monorepo",
    "prettier",
    "prettier-config",
    "storm",
    "storm-ops",
    "sullivanpj"
  ],
  "homepage": "https://stormsoftware.com",
  "bugs": "https://github.com/storm-software/storm-ops/issues",
  "repository": {
    "type": "github",
    "url": "https://github.com/storm-software/storm-ops.git",
    "directory": "packages/prettier"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Storm Software",
    "email": "contact@stormsoftware.com",
    "url": "https://stormsoftware.com"
  },
  "type": "module",
  "exports": {
    ".": {
      "require": {
        "types": "./index.d.cts",
        "default": "./index.cjs"
      },
      "import": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      },
      "default": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      }
    },
    "./index": {
      "require": {
        "types": "./index.d.cts",
        "default": "./index.cjs"
      },
      "import": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      },
      "default": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      }
    },
    "./config": {
      "require": {
        "types": "./index.d.cts",
        "default": "./index.cjs"
      },
      "import": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      },
      "default": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      }
    },
    "./recommended": {
      "require": {
        "types": "./index.d.cts",
        "default": "./index.cjs"
      },
      "import": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      },
      "default": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      }
    },
    "./.prettierignore": "./.prettierignore",
    "./.prettierignore-exclude-packagejson": "./.prettierignore-exclude-packagejson",
    "./all.json": "./all.json",
    "./base.json": "./base.json",
    "./recommended.json": "./recommended.json",
    "./exclude-packagejson.json": "./exclude-packagejson.json",
    "./config.json": "./config.json",
    "./jsdoc.json": "./jsdoc.json",
    "./prisma.json": "./prisma.json",
    "./solidity.json": "./solidity.json",
    "./tailwindcss.json": "./tailwindcss.json",
    "./package.json": "./package.json"
  },
  "main": "./index.cjs",
  "types": "./index.d.cts",
  "typings": "./index.d.mts",
  "files": [
    "./.prettierignore",
    "./.prettierignore-exclude-packagejson",
    "./*.json",
    "./*.cjs",
    "./*.d.cts",
    "./*.mjs",
    "./*.d.mts"
  ],
  "dependencies": {
    "prettier-plugin-jsdoc": "^1.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "catalog:",
    "prettier-plugin-sh": "^0.15.0",
    "prettier-plugin-toml": "^2.0.6"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-prisma": "^5.0.0",
    "prettier-plugin-solidity": "^1.4.3",
    "prettier-plugin-tailwindcss": "^0.6.14"
  },
  "peerDependencies": {
    "prettier": "catalog:",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-organize-imports": "^4.0.0",
    "prettier-plugin-packagejson": "^3.0.0",
    "prettier-plugin-prisma": "^5.0.0",
    "prettier-plugin-sh": "^0.15.0",
    "prettier-plugin-solidity": "1.3.1",
    "prettier-plugin-tailwindcss": "0.6.5",
    "prettier-plugin-toml": "^2.0.4"
  },
  "peerDependenciesMeta": {
    "prettier": {
      "optional": false
    },
    "prettier-plugin-astro": {
      "optional": true
    },
    "prettier-plugin-organize-imports": {
      "optional": false
    },
    "prettier-plugin-packagejson": {
      "optional": false
    },
    "prettier-plugin-prisma": {
      "optional": true
    },
    "prettier-plugin-sh": {
      "optional": false
    },
    "prettier-plugin-solidity": {
      "optional": true
    },
    "prettier-plugin-tailwindcss": {
      "optional": true
    },
    "prettier-plugin-toml": {
      "optional": false
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
