{
  "name": "eslint-plugin-tsdoc",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/eslint-plugin-tsdoc/src",
  "targets": {
    "build-base": {
      "executor": "nx:run-commands",
      "dependsOn": ["clean", "^build"],
      "options": {
        "command": "tsdown --config=tsdown.config.ts",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["build-base"],
      "options": {
        "commands": [
          "pnpm copyfiles LICENSE dist/packages/eslint-plugin-tsdoc",
          "pnpm copyfiles --up=2 ./packages/eslint-plugin-tsdoc/*.md ./packages/eslint-plugin-tsdoc/package.json dist/packages/eslint-plugin-tsdoc",
          "pnpm copyfiles --up=3 \"./packages/eslint-plugin-tsdoc/dist/**/*\" dist/packages/eslint-plugin-tsdoc/dist"
        ]
      }
    },
    "nx-release-publish": {
      "executor": "@storm-software/workspace-tools:npm-publish"
    }
  },
  "tags": ["platform:node"]
}
